{
  "name": "domicoop-server",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=.env --watch src/index.ts",
    "start": "bun --env-file=.env src/index.ts",
    "lint": "bunx tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cleanup:notifications": "bun --env-file=.env src/jobs/cleanupNotifications.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.9.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@supabase/supabase-js": "^2.103.0",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.5.1",
    "expo-server-sdk": "^6.1.0"
  }
}
